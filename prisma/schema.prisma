// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum LikeType {
  LIKE
  DISLIKE
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String         @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  videos        Video[]
  comments      Comment[]
  videoLikes    VideoLike[]
  commentLikes  CommentLike[]
  collections   Collection[]
  watchHistory  WatchHistory[]
  subscriptions Subscription[] @relation("subscriber")
  subscribers   Subscription[] @relation("channel")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Video {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  cloudinaryId    String
  url             String
  thumbnail       String?
  duration        Int? // seconds
  tags            String[]
  views           Int              @default(0)
  owner           User             @relation(fields: [ownerId], references: [id])
  ownerId         String           @db.ObjectId
  comments        Comment[]
  likes           VideoLike[]
  collectionItems CollectionItem[]
  watchHistory    WatchHistory[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Comment {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  body      String
  author    User          @relation(fields: [authorId], references: [id])
  authorId  String        @db.ObjectId
  video     Video         @relation(fields: [videoId], references: [id])
  videoId   String        @db.ObjectId
  parentId  String?       @db.ObjectId // null = top-level, set = reply
  likes     CommentLike[]
  createdAt DateTime      @default(now())
}

model VideoLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      LikeType
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  video     Video    @relation(fields: [videoId], references: [id])
  videoId   String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId, type])
}

model CommentLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      LikeType
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  comment   Comment  @relation(fields: [commentId], references: [id])
  commentId String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId, type])
}

model Collection {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  owner     User             @relation(fields: [ownerId], references: [id])
  ownerId   String           @db.ObjectId
  name      String
  items     CollectionItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([ownerId, createdAt])
}

model CollectionItem {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String     @db.ObjectId
  video        Video      @relation(fields: [videoId], references: [id])
  videoId      String     @db.ObjectId
  addedAt      DateTime   @default(now())

  @@unique([collectionId, videoId])
  @@index([videoId])
}

model WatchHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  video     Video    @relation(fields: [videoId], references: [id])
  videoId   String   @db.ObjectId
  watchedAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId, watchedAt])
}

model Subscription {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  subscriber   User     @relation("subscriber", fields: [subscriberId], references: [id])
  subscriberId String   @db.ObjectId
  channel      User     @relation("channel", fields: [channelId], references: [id])
  channelId    String   @db.ObjectId
  createdAt    DateTime @default(now())

  @@unique([subscriberId, channelId])
}
